          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "IF EXISTS(\r\n    SELECT 1\r\n    FROM \r\n    sys.dm_tran_locks bl\r\n\tJOIN \r\n\t\tsys.dm_os_waiting_tasks wt ON bl.lock_owner_address = wt.resource_address\r\n\tJOIN \r\n\t\tsys.dm_exec_requests req ON bl.request_session_id = req.session_id\r\n\tCROSS APPLY \r\n\t\tsys.dm_exec_sql_text(req.sql_handle) AS txt\r\n\r\n)\r\nBEGIN\r\n    SELECT\r\n\t\tbl.request_session_id AS Sesion_Bloqueada,\r\n\t\twt.blocking_session_id AS Sesion_Bloqueadora,\r\n\t\tDB_NAME(req.database_id) AS Base_De_Datos,\r\n\t\treq.wait_time / 1000.0 AS Tiempo_Espera_Seg,\r\n\t\tLEFT(txt.text, 200) AS Consulta_Bloqueada -- solo primeros 200 caracteres\r\n\tFROM \r\n\t\tsys.dm_tran_locks bl\r\n\tJOIN \r\n\t\tsys.dm_os_waiting_tasks wt ON bl.lock_owner_address = wt.resource_address\r\n\tJOIN \r\n\t\tsys.dm_exec_requests req ON bl.request_session_id = req.session_id\r\n\tCROSS APPLY \r\n\t\tsys.dm_exec_sql_text(req.sql_handle) AS txt\r\n\tORDER BY \r\n\t\tTiempo_Espera_Seg DESC\r\nEND\r\nELSE\r\nBEGIN \r\n    SELECT \r\n        '' as Sesion_Bloqueada,\r\n\t\t'' as Sesion_Bloqueadora,\r\n\t\t'' as Base_De_Datos,\r\n\t\t'' as Tiempo_Espera_Seg,\r\n\t\t'' as Consulta_Bloqueada\r\nEND\r\n\r\n",
