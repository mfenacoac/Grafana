          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "USE Micoope_SMS;\r\n\r\n;WITH Minutos AS (\r\n    SELECT DATEADD(MINUTE,-360,DATEADD(MINUTE,DATEDIFF(MINUTE,0,GETDATE()),0)) AS [time]\r\n    UNION ALL\r\n    SELECT DATEADD(MINUTE,1,[time])\r\n    FROM Minutos\r\n    WHERE [time] < DATEADD(MINUTE,DATEDIFF(MINUTE,0,GETDATE()),0)\r\n)\r\nSELECT\r\n    m.[time],\r\n    ISNULL(x.Pendientes,0) AS Pendientes\r\nFROM Minutos m\r\nLEFT JOIN (\r\n    SELECT\r\n        DATEADD(MINUTE,DATEDIFF(MINUTE,0,FechaInsertado),0) AS [time],\r\n        COUNT(*) AS Pendientes\r\n    FROM cnt.smsxenviartt\r\n    WHERE EstadoEnvio = 'P'\r\n      AND $__timeFilter(FechaInsertado)\r\n    GROUP BY DATEADD(MINUTE,DATEDIFF(MINUTE,0,FechaInsertado),0)\r\n) x\r\n    ON m.[time] = x.[time]\r\nORDER BY m.[time]\r\nOPTION (MAXRECURSION 400);",
          "refId": "A",
          "sql": {
