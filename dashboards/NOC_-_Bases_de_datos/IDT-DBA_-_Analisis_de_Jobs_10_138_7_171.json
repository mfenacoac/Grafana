      "targets": [
        {
          "dataset": "ReportServer",
          "datasource": {
            "type": "mssql",
            "uid": "ff0g2y9j6qi2of"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH JobData AS (\r\n    SELECT \r\n        -- 1. Ajuste de Hora: +6 para convertir Guate (UTC-6) a UTC (Estándar de Grafana)\r\n        DATEADD(HOUR, 6, msdb.dbo.agent_datetime(h.run_date, h.run_time)) AS [time],\r\n        \r\n        -- 2. Cálculo de Fin + Ajuste de Hora\r\n        DATEADD(HOUR, 6, DATEADD(SECOND, \r\n            (h.run_duration/10000 * 3600) + ((h.run_duration/100) % 100 * 60) + (h.run_duration % 100), \r\n            msdb.dbo.agent_datetime(h.run_date, h.run_time)\r\n        )) AS [time_end],\r\n        \r\n        -- 3. Identificador (Nombre del Job)\r\n        j.name AS [Job],\r\n        \r\n        -- 4. Estado para el Semáforo\r\n        CASE WHEN h.run_status = 1 THEN 'OK' ELSE 'FALLIDO' END AS [Estado],\r\n        \r\n        -- 5. Duración real formateada para el Tooltip (HH:MM:SS)\r\n        STUFF(STUFF(RIGHT('000000' + CAST(h.run_duration AS VARCHAR(6)), 6), 5, 0, ':'), 3, 0, ':') AS [Duracion_Real]\r\n        \r\n    FROM msdb.dbo.sysjobs j\r\n    INNER JOIN msdb.dbo.sysjobhistory h ON j.job_id = h.job_id\r\n    WHERE h.step_id = 0 -- Solo el resultado global del job\r\n      \r\n      -- EXCLUSIÓN DE JOBS NATIVOS / SISTEMA\r\n      AND j.name NOT LIKE 'syspolicy%'\r\n      AND j.name NOT LIKE 'SSIS%'\r\n      AND j.name NOT LIKE 'sysutility%'\r\n      AND j.name NOT LIKE 'DatabaseBackup%'\r\n      -- Excluimos mantenimientos que no son de negocio si lo deseas:\r\n      -- AND j.name NOT LIKE 'Server Maintenance%' \r\n)\r\nSELECT * FROM JobData\r\nWHERE $__timeFilter([time])\r\nORDER BY [time] ASC",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Mapa de jobs - 10.138.7.171",
