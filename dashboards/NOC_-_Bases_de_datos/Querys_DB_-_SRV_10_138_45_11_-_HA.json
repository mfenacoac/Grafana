      "targets": [
        {
          "dataset": "AnalyticsImport",
          "datasource": {
            "type": "mssql",
            "uid": "dfj6dlki2skcgb"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "IF EXISTS(\r\n    SELECT 1\r\n    FROM sys.dm_tran_active_snapshot_database_transactions AS ast\r\n    JOIN sys.dm_tran_active_transactions AS at ON at.transaction_id = ast.transaction_id\r\n    JOIN sys.dm_exec_sessions AS ses ON ses.session_id = ast.session_id\r\n    JOIN sys.dm_exec_connections AS con ON con.session_id = ses.session_id\r\n)\r\nBEGIN\r\n    SELECT TOP 10 \r\n        ses.session_id AS [SesionID],\r\n        DB_NAME(ses.database_id) AS [Base de Datos],\r\n        ses.login_name AS [Usuario],\r\n        ses.program_name AS [Programa de Origen],\r\n        ses.status AS [Estatus],\r\n\t\tFORMAT(at.transaction_begin_time, 'dd/MM/yy  -  HH:mm:ss') AS [Inicio],\r\n        CASE \r\n\t\t\tWHEN DATEDIFF(SECOND, at.transaction_begin_time, GETDATE()) < 60 THEN 1\r\n\t\t\tELSE DATEDIFF(MINUTE, at.transaction_begin_time, GETDATE()) \r\n\t\tEND AS [Minutos Activa],\r\n        con.client_net_address AS [IP del Cliente],\r\n        ses.host_name AS [Host],\r\n        ISNULL(t.text, '-') AS [Consulta SQL]\r\n    FROM sys.dm_tran_active_snapshot_database_transactions AS ast\r\n    JOIN sys.dm_tran_active_transactions AS at ON at.transaction_id = ast.transaction_id\r\n    JOIN sys.dm_exec_sessions AS ses ON ses.session_id = ast.session_id\r\n    JOIN sys.dm_exec_connections AS con ON con.session_id = ses.session_id\r\n    LEFT JOIN sys.dm_exec_requests r ON ses.session_id = r.session_id\r\n    OUTER APPLY sys.dm_exec_sql_text(r.sql_handle) AS t\r\n    WHERE ast.elapsed_time_seconds > 5\r\n    ORDER BY at.transaction_begin_time \r\nEND\r\nELSE\r\nBEGIN \r\n    SELECT \r\n        '' AS [SesionID],\r\n        '' AS [Base de Datos],\r\n        '' AS [Usuario],\r\n        '' AS [Programa de Origen],\r\n        '' AS [Estatus],\r\n        '' AS [Inicio],\r\n        '' AS [Minutos Activa],\r\n        '' AS [IP del Cliente],\r\n        '' AS [Host],\r\n        '' AS [Consulta SQL]\r\nEND\r\n",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
