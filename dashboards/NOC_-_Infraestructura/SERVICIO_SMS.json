          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "USE Micoope_SMS;\r\n\r\nWITH Datos AS (\r\n    SELECT ISNULL(MAX(DATEDIFF(SECOND, FechaInsertado, GETDATE())), 0) AS SegundosTotales\r\n    FROM (\r\n        SELECT FechaInsertado\r\n        FROM cnt.smsxenviarft\r\n        WHERE EstadoEnvioCredito = 'P'\r\n          AND FechaInsertado >= CAST(GETDATE() AS DATE)\r\n          AND FechaInsertado < DATEADD(DAY, 1, CAST(GETDATE() AS DATE))\r\n\r\n        UNION ALL\r\n\r\n        SELECT FechaInsertado\r\n        FROM cnt.smsxenviarft\r\n        WHERE EstadoEnvioDebito = 'P'\r\n          AND FechaInsertado >= CAST(GETDATE() AS DATE)\r\n          AND FechaInsertado < DATEADD(DAY, 1, CAST(GETDATE() AS DATE))\r\n\r\n        UNION ALL\r\n\r\n        SELECT FechaInsertado\r\n        FROM cnt.smsxenviartt\r\n        WHERE EstadoEnvio = 'I'\r\n          AND FechaInsertado >= CAST(GETDATE() AS DATE)\r\n          AND FechaInsertado < DATEADD(DAY, 1, CAST(GETDATE() AS DATE))\r\n\r\n        UNION ALL\r\n\r\n        SELECT FechaInsertado\r\n        FROM cnt.smsxenviaraa\r\n        WHERE EstadoEnvio = 'I'\r\n          AND FechaInsertado >= CAST(GETDATE() AS DATE)\r\n          AND FechaInsertado < DATEADD(DAY, 1, CAST(GETDATE() AS DATE))\r\n    ) A\r\n)\r\nSELECT\r\n    SegundosTotales / 86400 AS Dias,\r\n    (SegundosTotales % 86400) / 3600 AS Horas,\r\n    (SegundosTotales % 3600) / 60 AS Minutos,\r\n    SegundosTotales % 60 AS Segundos,\r\n    CONCAT(\r\n        SegundosTotales / 86400, 'd ',\r\n        (SegundosTotales % 86400) / 3600, 'h ',\r\n        (SegundosTotales % 3600) / 60, 'm ',\r\n        SegundosTotales % 60, 's'\r\n    ) AS TiempoMasAntiguo\r\nFROM Datos;",
          "refId": "A",
          "sql": {
            "columns": [
