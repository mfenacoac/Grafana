          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH CPU_Stats AS (\r\n    SELECT  \r\n        total_worker_time / execution_count AS AvgCPU,\r\n        execution_count,\r\n        total_worker_time AS TotalCPU,\r\n        text AS Consulta\r\n    FROM sys.dm_exec_query_stats \r\n    CROSS APPLY sys.dm_exec_sql_text(sql_handle)\r\n)\r\nSELECT TOP 5\r\n    Consulta,\r\n    (TotalCPU * 100.0 / SUM(TotalCPU) OVER()) AS 'Porcentaje CPU'\r\nFROM CPU_Stats\r\nORDER BY 'Porcentaje CPU' DESC;\r\n",
