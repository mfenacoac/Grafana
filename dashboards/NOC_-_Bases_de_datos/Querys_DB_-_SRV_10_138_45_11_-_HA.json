          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "IF EXISTS (SELECT 1 FROM sys.dm_exec_requests WHERE blocking_session_id <> 0)\r\nBEGIN\r\n    SELECT \r\n        -- 1. INFORMACIÓN DE LA SESIÓN BLOQUEADA (La víctima)\r\n        r.session_id AS 'Sesion Bloqueada',\r\n        s_blocked.login_name AS 'Usuario Bloqueado',\r\n        s_blocked.host_name AS 'Servidor Bloqueado',\r\n        s_blocked.program_name AS 'App Bloqueada',\r\n        DB_NAME(r.database_id) AS 'Base de Datos',\r\n        CAST(r.wait_time / 1000.0 AS DECIMAL(10,2)) AS 'Segundos Activa',\r\n        r.wait_type AS 'Tipo de Espera',\r\n        LEFT(t_blocked.text, 200) AS 'Consulta Bloqueada',\r\n\r\n        -- 2. INFORMACIÓN DE LA SESIÓN BLOQUEADORA (El responsable)\r\n        r.blocking_session_id AS 'Sesion Bloqueadora',\r\n        s_blocker.login_name AS 'Usuario Bloqueador',\r\n        s_blocker.host_name AS 'Servidor Bloqueador',\r\n        s_blocker.program_name AS 'App Bloqueadora',\r\n        s_blocker.status AS 'Estado Bloqueador',\r\n        LEFT(t_blocker.text, 200) AS 'Ultima Consulta Bloqueador'\r\n\r\n    FROM sys.dm_exec_requests r\r\n    -- Unimos con sesiones para obtener datos de la VÍCTIMA\r\n    INNER JOIN sys.dm_exec_sessions s_blocked \r\n        ON r.session_id = s_blocked.session_id\r\n    OUTER APPLY sys.dm_exec_sql_text(r.sql_handle) t_blocked\r\n    \r\n    -- Unimos con sesiones para obtener datos del RESPONSABLE\r\n    LEFT JOIN sys.dm_exec_sessions s_blocker \r\n        ON r.blocking_session_id = s_blocker.session_id\r\n    -- Unimos con conexiones para saber qué fue lo último que ejecutó el bloqueador\r\n    LEFT JOIN sys.dm_exec_connections c_blocker \r\n        ON s_blocker.session_id = c_blocker.session_id\r\n    OUTER APPLY sys.dm_exec_sql_text(c_blocker.most_recent_sql_handle) t_blocker\r\n\r\n    WHERE r.blocking_session_id <> 0\r\n    ORDER BY r.wait_time DESC;\r\nEND\r\nELSE\r\nBEGIN \r\n    -- Se devuelven las mismas columnas vacías si no hay bloqueos\r\n    SELECT \r\n        '' AS 'Sesion Bloqueada',\r\n        '' AS 'Usuario Bloqueado',\r\n        '' AS 'Servidor Bloqueado',\r\n        '' AS 'App Bloqueada',\r\n        '' AS 'Base de Datos',\r\n        '' AS 'Segundos Activa',\r\n        '' AS 'Tipo de Espera',\r\n        '' AS 'Consulta Bloqueada',\r\n        '' AS 'Sesion Bloqueadora',\r\n        '' AS 'Usuario Bloqueador',\r\n        '' AS 'Servidor Bloqueador',\r\n        '' AS 'App Bloqueadora',\r\n        '' AS 'Estado Bloqueador',\r\n        '' AS 'Ultima Consulta Bloqueador';\r\nEND",
          "refId": "A",
