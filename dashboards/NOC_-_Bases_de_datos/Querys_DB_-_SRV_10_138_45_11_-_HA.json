          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "-- CPU ALTO\r\nSELECT TOP 10\r\n    conn.session_id              AS SesionID,\r\n    sess.login_name              AS Usuario,\r\n    sess.host_name               AS HostName,\r\n    sess.program_name            AS Programa,\r\n    DB_NAME(req.database_id)     AS BaseDatos,\r\n\r\n    sess.status                  AS EstadoSesion,\r\n    req.status                   AS EstadoRequest,\r\n    --req.command                  AS Comando,\r\n\r\n    --req.wait_type                AS TipoEspera,\r\n    req.wait_time                AS Espera_ms,\r\n\r\n    req.cpu_time                 AS CPU_ms,\r\n    req.logical_reads            AS LecturasLogicas,\r\n\r\n    --conn.net_transport           AS TransporteRed,\r\n    conn.client_net_address      AS IP_Cliente,\r\n    conn.connect_time            AS HoraInicio,\r\n\r\n    LEFT(REPLACE(sqltext.text, CHAR(10), ' '), 300) AS Consulta\r\nFROM sys.dm_exec_connections conn\r\nJOIN sys.dm_exec_sessions sess \r\n    ON conn.session_id = sess.session_id\r\nLEFT JOIN sys.dm_exec_requests req  \r\n    ON conn.session_id = req.session_id\r\nOUTER APPLY sys.dm_exec_sql_text(req.sql_handle) AS sqltext\r\nWHERE req.session_id IS NOT NULL\r\n  AND req.cpu_time > 0\r\nORDER BY req.cpu_time DESC, req.wait_time DESC;\r\n",
          "refId": "A",
          "sql": {
