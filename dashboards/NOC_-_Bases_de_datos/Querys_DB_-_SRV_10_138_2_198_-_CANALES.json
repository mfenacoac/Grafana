          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "USE SoyFriDB;\r\n\r\nSELECT TOP 5\r\n    t.NAME AS Tabla,\r\n    s.Name AS Esquema,\r\n    CAST(ROUND((SUM(a.total_pages) * 8) / 1024.00, 2) AS DECIMAL(10,2)) AS TamañoMB,\r\n    CAST(ROUND((SUM(a.used_pages) * 8) / 1024.00, 2) AS DECIMAL(10,2)) AS EspacioUsadoMB,\r\n    CAST(ROUND((SUM(a.data_pages) * 8) / 1024.00, 2) AS DECIMAL(10,2)) AS DatosMB\r\nFROM \r\n    sys.tables t\r\nINNER JOIN      \r\n    sys.indexes i ON t.object_id = i.object_id\r\nINNER JOIN \r\n    sys.partitions p ON i.object_id = p.object_id AND i.index_id = p.index_id\r\nINNER JOIN \r\n    sys.allocation_units a ON p.partition_id = a.container_id\r\nLEFT OUTER JOIN \r\n    sys.schemas s ON t.schema_id = s.schema_id\r\nWHERE \r\n    t.is_ms_shipped = 0\r\nGROUP BY \r\n    t.Name, s.Name, p.Rows\r\nORDER BY \r\n    TamañoMB DESC;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
