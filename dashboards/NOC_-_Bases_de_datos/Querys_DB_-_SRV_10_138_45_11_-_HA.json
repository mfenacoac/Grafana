          "rawSql": "IF EXISTS(\r\n    SELECT 1\r\n    FROM sys.dm_tran_active_snapshot_database_transactions AS ast\r\n    JOIN sys.dm_tran_active_transactions AS at ON at.transaction_id = ast.transaction_id\r\n    JOIN sys.dm_exec_sessions AS ses ON ses.session_id = ast.session_id\r\n    JOIN sys.dm_exec_connections AS con ON con.session_id = ses.session_id\r\n    WHERE ast.elapsed_time_seconds > 0\r\n    --AND ses.program_name <> 'Microsoft JDBC Driver for SQL Server'\r\n    AND ses.program_name LIKE '%jTDS%'\r\n)\r\nBEGIN\r\n    SELECT TOP 10 \r\n        ses.session_id AS [Session ID],\r\n        DB_NAME(database_id) AS [Database Name],\r\n        CASE at.transaction_state\r\n            WHEN 0 THEN 'init'\r\n            WHEN 1 THEN 'init'\r\n            WHEN 2 THEN 'active'\r\n            WHEN 3 THEN 'ended'\r\n            WHEN 4 THEN 'committing'\r\n            WHEN 6 THEN 'committed'\r\n            WHEN 7 THEN 'rolling back'\r\n            ELSE 'other'\r\n        END AS [Transaction State],\r\n\t\tFORMAT(at.transaction_begin_time, 'dd/MM/yy  -  HH:mm:ss') AS [Transaction Start Time],\r\n        ast.elapsed_time_seconds AS [Elapsed Time],\r\n        CASE \r\n            WHEN at.transaction_type = 1 THEN 'Read/Write'\r\n            WHEN at.transaction_type = 2 THEN 'Read-Only'\r\n            ELSE 'System'\r\n        END AS [Transaction Type],\r\n        ses.login_name AS [Login],\r\n        ses.program_name AS [Origin Program],\r\n        con.client_net_address AS [Client IP],\r\n        ses.host_name AS [Host Name]\r\n    FROM sys.dm_tran_active_snapshot_database_transactions AS ast\r\n    JOIN sys.dm_tran_active_transactions AS at ON at.transaction_id = ast.transaction_id\r\n    JOIN sys.dm_exec_sessions AS ses ON ses.session_id = ast.session_id\r\n    JOIN sys.dm_exec_connections AS con ON con.session_id = ses.session_id\r\n WHERE ast.elapsed_time_seconds > 0\r\n    --AND ses.program_name <> 'Microsoft JDBC Driver for SQL Server'\r\n    AND ses.program_name LIKE '%jTDS%'\r\n    ORDER BY at.transaction_begin_time \r\nEND\r\nELSE\r\nBEGIN \r\n    SELECT \r\n        '' AS [Session ID],\r\n        '' AS [Database Name],\r\n        '' AS [Transaction State],\r\n        '' AS [Transaction Start Time],\r\n        '' AS [Elapsed Time],\r\n        '' AS [Transaction Type],\r\n        '' AS [Login],\r\n        '' AS [Origin Program],\r\n        '' AS [Client IP],\r\n        '' AS [Host Name]\r\nEND\r\n ",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Sesiones Activas Jbloader - T24 JDBC",
      "type": "table"
    },
